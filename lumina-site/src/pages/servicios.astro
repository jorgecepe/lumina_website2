---
import Layout from '../layouts/Layout.astro';

const coreServices = [
  {
    slug: "business-intelligence",
    title: "Business Intelligence y control de gestión",
    description: "Primero definimos qué debería medir tu gerencia para ejecutar la estrategia. Después lo montamos en dashboards conectados a tu ERP que se actualizan solos.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />`,
    highlights: ["KPIs + Dashboards", "Power BI / Looker", "Softland / SAP B1"]
  },
  {
    slug: "automatizacion-y-agentes-ia",
    title: "Automatización y agentes de IA",
    description: "Tres familias: flujos automáticos entre sistemas (n8n), agentes de IA con tu información (RAG), y asistentes conversacionales conectados a tu operación.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />`,
    highlights: ["n8n + Python", "Agentes RAG", "WhatsApp + web"]
  },
  {
    slug: "rpa-plataformas-sin-api",
    title: "Automatización de plataformas sin API",
    description: "Portales de cumplimiento, sistemas legacy, plataformas regulatorias. Si la plataforma no tiene API, automatizamos la carga con Playwright y análisis asistido por IA.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
    highlights: ["Playwright + IA", "Monitoreo 24/7", "Trazabilidad auditada"]
  },
  {
    slug: "soluciones-a-medida",
    title: "Soluciones a medida e infraestructura",
    description: "Aplicaciones web, integraciones, agentes específicos, infraestructura cloud gestionada. Cuando lo estándar no calza, construimos lo que necesitas y lo mantenemos en producción.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />`,
    highlights: ["Web apps", "Cloud gestionada", "SaaS propio"]
  },
];

const moreServices = [
  {
    slug: "inteligencia-competitiva",
    title: "Inteligencia competitiva",
    description: "Monitoreo diario de precios y posicionamiento de tu competencia, con alertas automáticas.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />`,
    highlights: ["Monitoreo diario", "Alertas", "Rankings"]
  },
  {
    slug: "hr-analytics",
    title: "HR Analytics y organigramas",
    description: "Visibilidad sobre dotación, rotación, costos laborales y desempeño. Puerta natural hacia NodalTree.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />`,
    highlights: ["Rotación", "NodalTree", "People analytics"]
  },
  {
    slug: "capacitacion",
    title: "Capacitación corporativa",
    description: "Power BI, análisis de datos, automatización y herramientas de IA. Dictada por el mismo profesor de Data Analytics en UANDES. Con tus datos reales, no ejemplos de libro.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />`,
    highlights: ["UANDES + PL-300", "Datos reales", "Presencial/online"]
  },
];

const modalidades = [
  {
    nombre: "Diagnóstico y sprint",
    descripcion: "Quieres ver valor concreto rápido. Definimos el primer entregable, lo construimos y lo dejamos en producción.",
    duracion: "4 a 8 semanas",
    inversion: "Desde 50 UF",
    aplica: "Primer proyecto con Lumina, dashboard puntual, automatización de un proceso específico."
  },
  {
    nombre: "Programa por fases",
    descripcion: "Hay un proyecto más grande con varios entregables encadenados. Cada fase se aprueba, se entrega y se factura antes de comenzar la siguiente.",
    duracion: "2 a 4 meses",
    inversion: "Desde 110 UF",
    aplica: "Implementación completa de Business Intelligence, multiple plataformas RPA, migración de sistemas."
  },
  {
    nombre: "Acompañamiento mensual",
    descripcion: "Ya tienes una operación corriendo y necesitas mantenimiento, mejoras continuas y disponibilidad para temas nuevos. Dos variantes: horas mensuales contratadas o servicio mensual con SLA fijo.",
    duracion: "Renovable cada 3 a 6 meses",
    inversion: "Desde 15 UF/mes",
    aplica: "Mantenimiento de robots RPA, operación continua de pipelines, SLA sobre dashboards en producción."
  },
];
---

<Layout
  title="Servicios | BI, automatización, RPA, IA y soluciones a medida | Lumina Consulting"
  description="Business Intelligence, automatización con agentes de IA, RPA para plataformas sin API, soluciones a medida, inteligencia competitiva, HR analytics y capacitación para empresas medianas en Chile."
>
  <!-- Hero Section -->
  <section class="relative py-12 md:py-14 bg-lum-black overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/4 -right-32 w-96 h-96 bg-lum-coral/15 rounded-full blur-3xl" />
      <div class="absolute bottom-0 -left-32 w-96 h-96 bg-lum-coral/10 rounded-full blur-3xl" />
    </div>
    <div class="container-custom relative">
      <div class="max-w-4xl mx-auto text-center">
        <span class="badge bg-white/10 text-white border-white/20 mb-6">Servicios</span>
        <h1 class="text-white mb-6">Lo que hacemos</h1>
        <p class="text-xl text-lum-slate-light max-w-2xl mx-auto">
          Cuatro líneas principales, tres complementarias. Datos, automatización e inteligencia para empresas que quieren decidir mejor.
        </p>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="py-20 bg-white">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <p class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-8">Líneas principales</p>
        <div class="grid md:grid-cols-2 gap-6 mb-16">
          {coreServices.map(service => (
            <a
              href={`/servicios/${service.slug}`}
              class="group card-elevated hover:border-lum-coral transition-all duration-300"
            >
              <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 bg-lum-coral/10 flex-shrink-0 flex items-center justify-center border-2 border-lum-black">
                  <svg class="w-6 h-6 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={service.icon} />
                </div>
              </div>
              <h2 class="text-xl font-semibold text-lum-black group-hover:text-lum-coral transition-colors mb-3">
                {service.title}
              </h2>
              <p class="text-lum-slate mb-4 text-sm">{service.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {service.highlights.map(h => (
                  <span class="font-mono text-mono-xs px-2 py-1 bg-lum-cream border border-lum-border">{h}</span>
                ))}
              </div>
              <span class="inline-flex items-center text-lum-coral font-mono text-mono-sm group-hover:gap-2 transition-all">
                Ver más
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </a>
          ))}
        </div>

        <p class="font-mono text-mono-xs text-lum-mocha uppercase tracking-wider mb-8">Servicios complementarios</p>
        <div class="grid md:grid-cols-3 gap-6">
          {moreServices.map(service => (
            <a
              href={`/servicios/${service.slug}`}
              class="group card-subtle hover:border-lum-mocha transition-all duration-300"
            >
              <div class="w-10 h-10 bg-lum-mocha/10 flex-shrink-0 flex items-center justify-center border border-lum-border mb-3">
                <svg class="w-5 h-5 text-lum-mocha" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={service.icon} />
              </div>
              <h3 class="text-lg font-semibold text-lum-black group-hover:text-lum-mocha transition-colors mb-2">
                {service.title}
              </h3>
              <p class="text-lum-slate text-sm mb-3">{service.description}</p>
              <span class="inline-flex items-center text-lum-mocha font-mono text-mono-xs group-hover:gap-1 transition-all">
                Ver más →
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Cómo trabajamos: modalidades -->
  <section class="py-20 bg-lum-cream">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <p class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-4">Modalidades</p>
          <h2 class="mb-4">Cómo trabajamos</h2>
          <p class="text-lg text-lum-slate max-w-3xl mx-auto">
            Tres formatos según el momento del problema. La mayoría de las relaciones empiezan en uno y migran a otro con el tiempo.
          </p>
        </div>

        <div class="space-y-6">
          {modalidades.map(m => (
            <div class="bg-white border-2 border-lum-black p-8" style="box-shadow: 4px 4px 0 0 #1a1814;">
              <div class="grid md:grid-cols-4 gap-6 items-start">
                <div class="md:col-span-2">
                  <h3 class="text-xl font-semibold mb-3">{m.nombre}</h3>
                  <p class="text-lum-slate text-sm mb-3">{m.descripcion}</p>
                  <p class="text-xs text-lum-slate-light">{m.aplica}</p>
                </div>
                <div class="md:border-l-2 md:border-lum-border md:pl-6">
                  <p class="font-mono text-mono-xs text-lum-slate uppercase tracking-wider mb-2">Duración</p>
                  <p class="text-sm text-lum-black">{m.duracion}</p>
                </div>
                <div class="md:border-l-2 md:border-lum-border md:pl-6">
                  <p class="font-mono text-mono-xs text-lum-slate uppercase tracking-wider mb-2">Inversión</p>
                  <p class="text-lg font-semibold text-lum-coral">{m.inversion}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 p-6 bg-white rounded-xl border border-lum-border">
          <p class="text-sm text-lum-slate">
            <strong class="text-lum-black">Todas las modalidades incluyen</strong> documentación técnica completa, código fuente, transferencia de conocimiento al equipo y sin lock-in de proveedor. Los rangos son orientativos y se ajustan según alcance. El presupuesto final se cierra tras el diagnóstico.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cómo trabajo (proceso) -->
  <section class="py-20 bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-center mb-12">Proceso de trabajo</h2>
        <div class="space-y-8">
          <div class="flex gap-6">
            <span class="w-10 h-10 rounded-full bg-lum-coral text-white flex-shrink-0 flex items-center justify-center font-semibold">1</span>
            <div>
              <h3 class="text-lg font-semibold mb-2">Conversamos</h3>
              <p class="text-lum-slate">
                Nos cuentas qué problema quieres resolver. Sin compromiso, sin PowerPoints eternos. Una conversación honesta sobre si podemos ayudarte o no.
              </p>
            </div>
          </div>
          <div class="flex gap-6">
            <span class="w-10 h-10 rounded-full bg-lum-coral text-white flex-shrink-0 flex items-center justify-center font-semibold">2</span>
            <div>
              <h3 class="text-lg font-semibold mb-2">Diagnóstico</h3>
              <p class="text-lum-slate">
                Revisamos tus datos, procesos y contexto. Te decimos qué es realista lograr, en cuánto tiempo, y cuánto costaría. Si no tiene sentido, te lo decimos también.
              </p>
            </div>
          </div>
          <div class="flex gap-6">
            <span class="w-10 h-10 rounded-full bg-lum-coral text-white flex-shrink-0 flex items-center justify-center font-semibold">3</span>
            <div>
              <h3 class="text-lg font-semibold mb-2">Ejecución</h3>
              <p class="text-lum-slate">
                Trabajamos rápido, con entregas parciales para que puedas usar las cosas apenas estén listas. Sin sorpresas ni cambios de alcance a mitad de camino.
              </p>
            </div>
          </div>
          <div class="flex gap-6">
            <span class="w-10 h-10 rounded-full bg-lum-coral text-white flex-shrink-0 flex items-center justify-center font-semibold">4</span>
            <div>
              <h3 class="text-lg font-semibold mb-2">Operación y transferencia</h3>
              <p class="text-lum-slate">
                Operamos lo que construimos: pipelines en producción con monitoreo, agentes con retraining, infraestructura con SLA. Los sistemas detectan las fallas antes que tu equipo, y las resolvemos dentro del SLA acordado. Capacitamos al equipo para que puedan mantener y evolucionar lo que construimos.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-lum-black relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-lum-coral/10 rounded-full blur-3xl" />
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-lum-coral/10 rounded-full blur-3xl" />
    </div>
    <div class="container-custom relative">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-white mb-6">¿No sabes por dónde empezar?</h2>
        <p class="text-xl text-lum-slate-light mb-10">
          Cuéntanos qué problema tienes y vemos juntos si tiene sentido trabajar en ello.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://wa.me/56991629095?text=Hola,%20me%20interesa%20conocer%20más%20sobre%20los%20servicios%20de%20Lumina%20Consulting"
            target="_blank"
            class="btn-primary"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Contactar por WhatsApp
          </a>
          <a href="/contacto" class="btn-secondary bg-white/5 border-white/20 text-white hover:bg-white/10">
            Agendar una llamada
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
