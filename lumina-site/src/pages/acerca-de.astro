---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Acerca de Jorge Cepeda | Lumina Consulting";
const pageDescription = `15 a${String.fromCharCode(241)}os en control de gesti${String.fromCharCode(243)}n financiero. Hoy ayudo a empresas medianas a conectar sus datos, automatizar lo repetitivo y construir sistemas de decisi${String.fromCharCode(243)}n que realmente se usan.`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
>
  <!-- Hero Section -->
  <section class="relative py-16 md:py-24 bg-lum-black overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/4 -right-32 w-96 h-96 bg-lum-coral/15 rounded-full blur-3xl" />
      <div class="absolute bottom-0 -left-32 w-96 h-96 bg-lum-coral/10 rounded-full blur-3xl" />
    </div>
    <div class="container-custom relative">
      <div class="max-w-4xl mx-auto text-center">
        <span class="badge bg-white/10 text-white border-white/20 mb-6">Qui&#233;n soy</span>
        <h1 class="text-white mb-6">Jorge Cepeda</h1>
        <p class="text-xl text-lum-slate-light max-w-2xl mx-auto">
          Control de gesti&#243;n, datos y automatizaci&#243;n para empresas que ya no pueden depender de Excel
        </p>
      </div>
    </div>
  </section>

  <!-- Qui&#233;n soy -->
  <section class="py-20 bg-white" id="fundador">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <!-- Photo -->
          <div class="scroll-fade">
            <div class="relative">
              <div class="absolute inset-0 bg-gradient-to-br from-lum-coral/20 to-lum-mocha/20 rounded-3xl transform rotate-3"></div>
              <img
                src="/jorge-cepeda.jpg"
                alt="Jorge Cepeda - Fundador de Lumina Consulting, MBA UC, Microsoft Certified Power BI Data Analyst"
                class="relative rounded-3xl shadow-xl w-full object-cover aspect-square"
              />
            </div>
          </div>

          <!-- Bio -->
          <div class="scroll-fade animation-delay-100">
            <p class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-4">Fundador</p>
            <h2 class="mb-6">Qui&#233;n soy</h2>

            <p class="text-lg text-lum-slate mb-4">
              Soy Jorge Cepeda. Llevo 15 a&#241;os dise&#241;ando sistemas de control de gesti&#243;n en la industria financiera &mdash; los &#250;ltimos a&#241;os en el holding de inversiones de un banco. Hoy aplico esa experiencia a empresas medianas que necesitan la misma visibilidad y control, sin los costos ni la complejidad de las soluciones enterprise.
            </p>
            <p class="text-lg text-lum-slate mb-4">
              Lumina Consulting es mi consultora. Trabajo con empresas que est&#225;n en el punto donde Excel ya no alcanza pero SAP enterprise es demasiado. Las ayudo a conectar sus datos, automatizar lo repetitivo, y construir sistemas de decisi&#243;n que realmente se usan.
            </p>
            <p class="text-lg text-lum-slate mb-8">
              Tambi&#233;n soy profesor de Advanced Data Analytics en la Universidad de los Andes, y certificado Microsoft PL-300 (Power BI Data Analyst).
            </p>

            <!-- Credentials Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
              <!-- MBA UC -->
              <div class="flex items-start gap-3 p-4 bg-lum-cream rounded-xl">
                <div class="w-10 h-10 rounded-lg bg-lum-coral/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-lum-black text-sm">MBA</p>
                  <p class="text-lum-slate text-xs">Pontificia Universidad Cat&#243;lica de Chile</p>
                </div>
              </div>

              <!-- Professor U. Andes -->
              <div class="flex items-start gap-3 p-4 bg-lum-cream rounded-xl">
                <div class="w-10 h-10 rounded-lg bg-lum-coral/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-lum-black text-sm">Profesor Data Analytics</p>
                  <p class="text-lum-slate text-xs">Universidad de los Andes</p>
                </div>
              </div>

              <!-- Microsoft Certified -->
              <div class="flex items-start gap-3 p-4 bg-lum-cream rounded-xl">
                <div class="w-10 h-10 rounded-lg bg-lum-coral/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-lum-black text-sm">Microsoft Certified</p>
                  <p class="text-lum-slate text-xs">Power BI Data Analyst (PL-300)</p>
                </div>
              </div>

              <!-- Experience -->
              <div class="flex items-start gap-3 p-4 bg-lum-cream rounded-xl">
                <div class="w-10 h-10 rounded-lg bg-lum-coral/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-lum-black text-sm">15+ a&#241;os experiencia</p>
                  <p class="text-lum-slate text-xs">Control de gesti&#243;n en industria financiera</p>
                </div>
              </div>
            </div>

            <!-- LinkedIn CTA -->
            <a
              href="https://www.linkedin.com/in/jorgecepeda/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-lum-coral hover:text-lum-mocha transition-colors font-medium"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              Ver perfil en LinkedIn
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Enfoque -->
  <section class="py-20 bg-lum-cream">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="mb-12 scroll-fade">
          <p class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-4">Filosof&#237;a</p>
          <h2>Enfoque</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="card-elevated scroll-fade">
            <span class="badge-coral mb-4">01</span>
            <h3 class="text-xl mb-3">Estrategia + ejecuci&#243;n</h3>
            <p class="text-lum-slate">
              No solo construyo dashboards &mdash; defino qu&#233; medir y por qu&#233;. Primero entiendo las decisiones que necesitas tomar, y despu&#233;s dise&#241;o la soluci&#243;n que las soporta.
            </p>
          </div>

          <div class="card-elevated scroll-fade animation-delay-100">
            <span class="badge-coral mb-4">02</span>
            <h3 class="text-xl mb-3">Automatizaci&#243;n real</h3>
            <p class="text-lum-slate">
              Los flujos que construyo est&#225;n en producci&#243;n. Robots que corren a las 7 AM, agentes que responden mensajes, reportes que llegan sin que nadie los pida.
            </p>
          </div>

          <div class="card-elevated scroll-fade animation-delay-200">
            <span class="badge-coral mb-4">03</span>
            <h3 class="text-xl mb-3">Sin dependencia</h3>
            <p class="text-lum-slate">
              Transfiero conocimiento. Tu equipo puede mantener lo que construimos. No busco contratos eternos &mdash; busco que el sistema funcione sin m&#237;.
            </p>
          </div>

          <div class="card-elevated scroll-fade animation-delay-300">
            <span class="badge-coral mb-4">04</span>
            <h3 class="text-xl mb-3">Foco en empresas medianas</h3>
            <p class="text-lum-slate">
              Entiendo los ERP que usan (Softland, SAP B1, Dynamics 365), los presupuestos que manejan, y los problemas reales. No vendo soluciones enterprise a quien no las necesita.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stack t&#233;cnico -->
  <section class="py-20 bg-white">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="mb-12 scroll-fade">
          <p class="font-mono text-mono-xs text-lum-mocha uppercase tracking-wider mb-4">Herramientas</p>
          <h2>Stack t&#233;cnico</h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 scroll-fade animation-delay-100">
          <div class="card-subtle text-center py-6">
            <p class="font-mono text-mono-sm text-lum-black font-semibold mb-1">Power BI</p>
            <span class="badge-coral text-[10px]">PL-300</span>
          </div>
          <div class="card-subtle text-center py-6">
            <p class="font-mono text-mono-sm text-lum-black font-semibold mb-1">Python</p>
            <span class="text-lum-slate text-xs">Pandas, FastAPI</span>
          </div>
          <div class="card-subtle text-center py-6">
            <p class="font-mono text-mono-sm text-lum-black font-semibold mb-1">SQL</p>
            <span class="text-lum-slate text-xs">SQL Server, Postgres</span>
          </div>
          <div class="card-subtle text-center py-6">
            <p class="font-mono text-mono-sm text-lum-black font-semibold mb-1">n8n</p>
            <span class="text-lum-slate text-xs">Automatizaci&#243;n</span>
          </div>
          <div class="card-subtle text-center py-6">
            <p class="font-mono text-mono-sm text-lum-black font-semibold mb-1">React / Next.js</p>
            <span class="text-lum-slate text-xs">Apps web</span>
          </div>
          <div class="card-subtle text-center py-6">
            <p class="font-mono text-mono-sm text-lum-black font-semibold mb-1">Supabase</p>
            <span class="text-lum-slate text-xs">Backend + Auth</span>
          </div>
        </div>

        <div class="mt-4 flex flex-wrap gap-3 scroll-fade animation-delay-200">
          <span class="badge-outline">GitHub Actions</span>
          <span class="badge-outline">Vercel</span>
          <span class="badge-outline">Astro</span>
          <span class="badge-outline">Tailwind CSS</span>
          <span class="badge-outline">OpenAI API</span>
          <span class="badge-outline">Anthropic API</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Industrias -->
  <section class="py-20 bg-lum-cream">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="mb-12 scroll-fade">
          <p class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-4">Experiencia sectorial</p>
          <h2>Industrias</h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Automotriz -->
          <div class="card scroll-fade">
            <span class="badge-coral mb-4">Automotriz</span>
            <ul class="arrow-list">
              <li>Inteligencia competitiva</li>
              <li>Control de precios</li>
              <li>Automatizaci&#243;n comercial</li>
            </ul>
          </div>

          <!-- Inmobiliario -->
          <div class="card scroll-fade animation-delay-100">
            <span class="badge-mocha mb-4">Inmobiliario</span>
            <ul class="arrow-list">
              <li>Control de gesti&#243;n</li>
              <li>Flujo de caja</li>
              <li>Integraci&#243;n Cloudbeds / Airbnb</li>
            </ul>
          </div>

          <!-- Financiero -->
          <div class="card scroll-fade animation-delay-200">
            <span class="badge-sage mb-4">Financiero / Banca</span>
            <ul class="arrow-list">
              <li>HR Analytics</li>
              <li>Organigramas</li>
              <li>Calibraci&#243;n de desempe&#241;o</li>
            </ul>
          </div>

          <!-- Salud -->
          <div class="card scroll-fade animation-delay-300">
            <span class="badge-coral mb-4">Salud / Veterinaria</span>
            <ul class="arrow-list">
              <li>Reporter&#237;a operacional</li>
              <li>Visibilidad financiera</li>
            </ul>
          </div>

          <!-- Servicios -->
          <div class="card scroll-fade animation-delay-400">
            <span class="badge-mocha mb-4">Servicios profesionales</span>
            <ul class="arrow-list">
              <li>Automatizaci&#243;n de procesos</li>
              <li>Infraestructura de datos</li>
            </ul>
          </div>

          <!-- Exportaci&#243;n -->
          <div class="card scroll-fade animation-delay-500">
            <span class="badge-sage mb-4">Exportaci&#243;n</span>
            <ul class="arrow-list">
              <li>Dashboards Dynamics 365</li>
              <li>Trazabilidad</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-lum-black relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-lum-coral/10 rounded-full blur-3xl" />
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-lum-coral/10 rounded-full blur-3xl" />
    </div>
    <div class="container-custom relative">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-white mb-6 scroll-fade">&#191;Cu&#225;nto te cuesta no ver c&#243;mo va tu negocio hoy?</h2>
        <p class="text-xl text-lum-slate-light mb-10 scroll-fade animation-delay-100">
          Conversemos sobre qu&#233; visibilidad te falta y c&#243;mo podemos resolverlo
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center scroll-fade animation-delay-200">
          <a
            href="https://wa.me/56991629095?text=Hola,%20me%20interesa%20conocer%20m%C3%A1s%20sobre%20Lumina%20Consulting"
            target="_blank"
            class="btn-primary"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Contactar por WhatsApp
          </a>
          <a href="/contacto" class="btn bg-transparent text-lum-cream border-lum-cream/30 hover:bg-lum-cream/10">
            Agendar llamada
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
