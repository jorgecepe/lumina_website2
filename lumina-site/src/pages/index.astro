---
import Layout from '../layouts/Layout.astro';
import WhatsAppIcon from '../components/icons/WhatsAppIcon.astro';
---

<Layout
  title="Lumina Consulting | Datos, automatización e inteligencia para empresas"
  description="Consultora chilena especializada en dashboards Power BI, automatización con IA, control de gestión y soluciones a medida para empresas medianas."
>
  <!-- SECTION 1: HERO -->
  <section class="relative min-h-[75vh] lg:min-h-[90vh] flex items-center bg-lum-cream overflow-hidden">
    <div class="hidden lg:block absolute top-20 right-10 w-32 h-32 border-2 border-lum-mocha/20 rotate-12" aria-hidden="true"></div>
    <div class="hidden lg:block absolute bottom-32 left-20 w-16 h-16 bg-lum-coral/10" aria-hidden="true"></div>
    <div class="hidden lg:block absolute top-1/3 right-1/4 w-4 h-4 bg-lum-coral" aria-hidden="true"></div>

    <div class="container-custom relative py-20">
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-8">
          <div class="flex items-center gap-3 mb-8 scroll-fade">
            <span class="w-12 h-px bg-lum-coral"></span>
            <span class="font-mono text-mono-sm text-lum-coral uppercase tracking-wider">Datos · Automatización · Inteligencia de negocio</span>
          </div>

          <h1 class="mb-8 scroll-fade delay-100">
            <span class="block text-lum-black">Conectamos tus datos</span>
            <span class="block">
              <span class="text-lum-black">para que </span>
              <span class="text-lum-coral italic">dejes de adivinar</span>
            </span>
          </h1>

          <p class="text-lg sm:text-xl md:text-2xl text-lum-slate max-w-2xl mb-10 scroll-fade delay-200">
            Conecto los sistemas que tu empresa ya usa — ERP, plataformas de venta, bases de datos — los automatizo, y te doy la
            <span class="text-highlight">visibilidad que necesitas</span>
            para tomar decisiones con información real.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 scroll-fade delay-300">
            <a
              href="https://wa.me/56991629095?text=Hola,%20me%20interesa%20conocer%20más%20sobre%20los%20servicios%20de%20Lumina%20Consulting"
              target="_blank"
              class="btn-primary w-full sm:w-auto"
            >
              <WhatsAppIcon />
              Conversemos
            </a>
            <a href="/servicios" class="btn-secondary w-full sm:w-auto">
              Ver servicios
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <div class="hidden lg:block lg:col-span-4 lg:translate-y-12 scroll-fade-right delay-400">
          <div class="relative -rotate-1">
            <div class="absolute inset-0 bg-lum-coral/20 translate-x-2 translate-y-2"></div>
            <img
              src="/images/chart3.png"
              alt="Dashboard de gestión con KPIs, gráficos de barras, distribución y tabla de procesos — Lumina Consulting"
              class="relative w-full border-2 border-lum-black opacity-95"
              width="800"
              height="451"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: SOCIAL PROOF STRIP -->
  <section class="py-10 bg-lum-ivory border-y border-lum-border">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8 md:gap-y-0 md:gap-x-8 items-center">
        <div class="text-center scroll-fade md:border-r md:border-lum-border">
          <span class="font-display text-4xl md:text-5xl text-lum-coral block">5+</span>
          <span class="font-mono text-mono-xs text-lum-slate uppercase tracking-wider">Industrias atendidas</span>
        </div>
        <div class="text-center scroll-fade delay-100 md:border-r md:border-lum-border">
          <span class="font-display text-4xl md:text-5xl text-lum-coral block">4,000+</span>
          <span class="font-mono text-mono-xs text-lum-slate uppercase tracking-wider">Empleados gestionados</span>
        </div>
        <div class="text-center scroll-fade delay-200 md:border-r md:border-lum-border">
          <span class="font-display text-4xl md:text-5xl text-lum-coral block">300+</span>
          <span class="font-mono text-mono-xs text-lum-slate uppercase tracking-wider">Vehículos monitoreados</span>
        </div>
        <div class="text-center scroll-fade delay-300">
          <span class="font-display text-4xl md:text-5xl text-lum-coral block">0</span>
          <span class="font-mono text-mono-xs text-lum-slate uppercase tracking-wider">Reportes manuales</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: THREE PILLARS -->
  <section class="section bg-lum-cream">
    <div class="container-custom">
      <div class="max-w-2xl mb-16 scroll-fade">
        <span class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-4 block">Qué hacemos</span>
        <h2>Tres formas de transformar tu operación</h2>
      </div>

      <div class="space-y-12 md:space-y-16">
        <!-- Pillar 1: Visibilidad -->
        <div class="border-l-4 border-lum-coral pl-8 md:pl-12 py-6 scroll-fade">
          <span class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider block mb-3">Ve tu negocio</span>
          <h3 class="mb-4">Tu operación en una pantalla — actualizada, sin pedirle a nadie</h3>
          <p class="text-lum-slate max-w-3xl mb-4">
            Conecto tu ERP, tus plataformas de venta y tus bases de datos a dashboards que se actualizan solos.
            La gerencia ve ventas, márgenes, flujo de caja y operación — consolidados, todos los días.
            Sin armar Excel, sin esperar al cierre de mes.
          </p>
          <p class="text-lum-slate max-w-3xl mb-6">
            Estado de resultados, presupuesto vs. real, KPIs con alertas. No solo construyo dashboards — defino contigo qué medir y por qué.
          </p>
          <p class="font-mono text-mono-sm text-lum-coral">
            > Grupo inmobiliario con 7 sociedades: de planillas mensuales a visibilidad diaria de flujo de caja
          </p>
          <div class="flex flex-wrap gap-4 mt-6">
            <a href="/servicios/dashboards-estrategicos" class="btn-ghost">
              Dashboards
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/servicios/control-de-gestion" class="btn-ghost">
              Control de gestión
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Pillar 2: Automatización -->
        <div class="border-l-4 border-lum-mocha pl-8 md:pl-12 py-6 scroll-fade">
          <span class="font-mono text-mono-xs text-lum-mocha uppercase tracking-wider block mb-3">Automatiza lo repetitivo</span>
          <h3 class="mb-4">Tus reportes, alertas y flujos de datos — sin intervención manual</h3>
          <p class="text-lum-slate max-w-3xl mb-4">
            Robots que corren a las 7 AM, agentes de IA que clasifican emails, reportes que llegan solos a tu correo.
            Automatizo con n8n, Python y GitHub Actions para que tu equipo deje de hacer trabajo mecánico.
          </p>
          <p class="text-lum-slate max-w-3xl mb-6">
            Incluye inteligencia competitiva: monitoreo diario de precios y posicionamiento de tu competencia, con alertas cuando algo se mueve.
          </p>
          <p class="font-mono text-mono-sm text-lum-mocha">
            > Red de automotoras: de 3 horas de trabajo manual diario a cero
          </p>
          <div class="flex flex-wrap gap-4 mt-6">
            <a href="/servicios/automatizacion-inteligente" class="btn-ghost">
              Automatización
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/servicios/inteligencia-competitiva" class="btn-ghost">
              Inteligencia competitiva
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Pillar 3: Construcción -->
        <div class="border-l-4 border-lum-sage pl-8 md:pl-12 py-6 scroll-fade">
          <span class="font-mono text-mono-xs text-lum-sage uppercase tracking-wider block mb-3">Si no existe, lo construimos</span>
          <h3 class="mb-4">Aplicaciones, herramientas e integraciones a la medida de tu operación</h3>
          <p class="text-lum-slate max-w-3xl mb-4">
            Cuando el problema no se resuelve con un dashboard ni con software del mercado, lo construyo.
            Aplicaciones web, herramientas internas, integraciones entre sistemas que no se hablan.
            Desde MVPs funcionales hasta productos SaaS.
          </p>
          <p class="text-lum-slate max-w-3xl mb-6">
            También capacitación aplicada — con tus datos reales, no con ejemplos de libro. Power BI, análisis de datos, automatización. Franquicia SENCE disponible.
          </p>
          <p class="font-mono text-mono-sm text-lum-sage">
            > NodalTree reemplazó software de USD 15,000/año en un banco con 4,000+ empleados
          </p>
          <div class="flex flex-wrap gap-4 mt-6">
            <a href="/servicios/soluciones-a-medida" class="btn-ghost">
              Soluciones a medida
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/servicios/capacitacion" class="btn-ghost">
              Capacitación
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: FOUNDER -->
  <section class="py-16 bg-lum-cream border-t border-lum-slate/10">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
          <div class="flex-shrink-0 scroll-fade">
            <a href="/acerca-de" class="block">
              <img
                src="/jorge-cepeda.jpg"
                alt="Jorge Cepeda - Fundador de Lumina Consulting"
                class="w-32 h-32 md:w-44 md:h-44 rounded-full object-cover border-4 border-white shadow-lg hover:scale-105 transition-transform"
                loading="lazy"
                width="176"
                height="176"
              />
            </a>
          </div>

          <div class="flex-grow text-center md:text-left scroll-fade delay-100">
            <p class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-2">Fundador</p>
            <h3 class="text-xl md:text-2xl font-display text-lum-black mb-3">
              Jorge Cepeda
            </h3>
            <p class="text-lum-slate text-sm mb-4">
              15 años diseñando sistemas de control de gestión en la industria financiera. Hoy aplico esa experiencia a empresas medianas que necesitan la misma visibilidad y control, sin los costos de las soluciones enterprise.
            </p>
            <div class="flex flex-wrap justify-center md:justify-start gap-3">
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white rounded-full text-sm text-lum-slate shadow-sm">
                <svg class="w-4 h-4 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                </svg>
                MBA UC
              </span>
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white rounded-full text-sm text-lum-slate shadow-sm">
                <svg class="w-4 h-4 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
                Profesor U. Andes
              </span>
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white rounded-full text-sm text-lum-slate shadow-sm">
                <svg class="w-4 h-4 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                </svg>
                Microsoft PL-300
              </span>
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white rounded-full text-sm text-lum-slate shadow-sm">
                <svg class="w-4 h-4 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                15+ años experiencia
              </span>
            </div>
          </div>

          <div class="flex-shrink-0 flex flex-col gap-3 scroll-fade delay-200">
            <a
              href="https://www.linkedin.com/in/jorgecepeda/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-lum-linkedin text-white rounded-lg hover:bg-lum-linkedin-dark transition-colors text-sm font-medium"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              Ver LinkedIn
            </a>
            <a href="/acerca-de" class="btn-ghost text-sm justify-center">
              Más sobre Lumina
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 5: CASES -->
  <section class="section bg-lum-cream">
    <div class="container-custom">
      <div class="max-w-2xl mb-16 scroll-fade">
        <span class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-4 block">Resultados reales</span>
        <h2>Casos de éxito</h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <!-- Case 1 -->
        <div class="border-l-4 border-lum-coral pl-8 py-4 scroll-fade">
          <div class="flex gap-3 mb-4">
            <span class="badge-coral">Automatización</span>
            <span class="badge-outline">Automotriz</span>
          </div>
          <h3 class="text-xl mb-3">Red de Automotoras — 300+ vehículos monitoreados diariamente</h3>
          <p class="text-lum-slate mb-4">
            De revisar precios a mano a recibir un ranking automatizado a las 7 AM. De 3 horas de trabajo manual a cero. Detección inmediata de errores de publicación y precios fuera de mercado.
          </p>
          <blockquote class="font-serif text-lg text-lum-charcoal italic mb-2">
            "Es como tener un analista 24/7 trabajando para nosotros."
          </blockquote>
          <p class="font-mono text-mono-xs text-lum-slate">— Gerente Comercial, red de automotoras en Chile</p>
        </div>

        <!-- Case 2 -->
        <div class="border-l-4 border-lum-mocha pl-8 py-4 lg:translate-y-12 scroll-fade delay-100">
          <div class="flex gap-3 mb-4">
            <span class="badge-mocha">Dashboards</span>
            <span class="badge-outline">Inmobiliario</span>
          </div>
          <h3 class="text-xl mb-3">Grupo Inmobiliario — 7 sociedades con visibilidad financiera unificada</h3>
          <p class="text-lum-slate mb-4">
            Datos dispersos en Softland, Cloudbeds y planillas. Hoy los socios ven flujo de caja real y proyectado en un mail semanal automático — sin intervención manual.
          </p>
          <blockquote class="font-serif text-lg text-lum-charcoal italic mb-2">
            "Pasamos de pedir reportes a tener la información esperándonos."
          </blockquote>
          <p class="font-mono text-mono-xs text-lum-slate">— Socio administrador, grupo inmobiliario</p>
        </div>
      </div>

      <div class="mt-12 text-center scroll-fade">
        <a href="/casos-de-exito" class="btn-secondary">
          Ver más casos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 6: NODALTREE -->
  <section class="section-mocha relative overflow-hidden">
    <div class="absolute top-10 right-10 w-40 h-40 border border-white/10 rotate-45" aria-hidden="true"></div>
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="scroll-fade">
          <span class="badge text-white border-white/30 mb-6">Producto propio</span>
          <h2 class="text-white mb-4">NodalTree</h2>
          <p class="text-white/60 font-mono text-mono-sm uppercase tracking-wider mb-6">Organigramas inteligentes desde tus datos</p>
          <p class="text-white/80 text-lg mb-6">
            Tu organigrama siempre actualizado, sin PowerPoint, sin software caro.
            Importa desde Excel, CSV o base de datos. Edición en vivo, exportación PDF.
            Multi-tenancy: cada empresa con su espacio.
          </p>
          <p class="font-mono text-mono-sm text-white/70 mb-8">
            > Usado por un banco con 4,000+ empleados. Reemplazó software de USD 15,000/año.
          </p>
          <a
            href="https://nodaltree.luminaconsulting.ai"
            target="_blank"
            rel="noopener noreferrer"
            class="btn bg-white text-lum-mocha-dark border-white hover:bg-lum-cream"
          >
            Probar NodalTree
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
        <div class="scroll-fade-right">
          <!-- TODO: Replace with real NodalTree screenshot showing an interactive org chart -->
          <div class="bg-white/10 border border-white/20 p-8 rotate-1">
            <img
              src="/logoNodalTree.png"
              alt="NodalTree — Organigramas interactivos desde tus datos"
              class="w-32 h-32 object-contain mx-auto opacity-90"
              loading="lazy"
              width="128"
              height="128"
            />
            <p class="text-white/40 text-center font-mono text-mono-xs mt-4">Vista previa próximamente</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 7: FINAL CTA -->
  <section class="section-dark relative overflow-hidden">
    <div class="absolute top-1/2 right-20 -translate-y-1/2 opacity-10" aria-hidden="true">
      <div class="w-32 h-px bg-lum-coral"></div>
      <div class="w-px h-32 bg-lum-coral absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
    </div>

    <div class="container-custom">
      <div class="max-w-3xl">
        <h2 class="text-lum-cream mb-6 scroll-fade">
          ¿Cuánto te cuesta no ver
          <span class="text-lum-coral italic">cómo va tu negocio hoy</span>?
        </h2>
        <p class="text-xl text-lum-slate-light mb-10 scroll-fade delay-100">
          Respondemos en menos de 24 horas. Sin compromiso.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 scroll-fade delay-200">
          <a
            href="https://wa.me/56991629095?text=Hola,%20me%20interesa%20conocer%20más%20sobre%20los%20servicios%20de%20Lumina%20Consulting"
            target="_blank"
            class="btn-primary"
