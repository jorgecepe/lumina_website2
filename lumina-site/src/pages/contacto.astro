---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacto | Conversemos sobre la visibilidad de tu negocio | Lumina Consulting"
  description="¿Cuánto te cuesta no ver cómo va tu negocio hoy? Conversemos sin compromiso. Respondemos en menos de 24 horas."
>
  <!-- Hero Section -->
  <section class="relative py-12 md:py-14 bg-lum-black overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/4 -right-32 w-96 h-96 bg-lum-coral/15 rounded-full blur-3xl" />
      <div class="absolute bottom-0 -left-32 w-96 h-96 bg-lum-coral/10 rounded-full blur-3xl" />
    </div>
    <div class="container-custom relative">
      <div class="max-w-4xl mx-auto text-center">
        <span class="badge bg-white/10 text-white border-white/20 mb-6">Contacto</span>
        <h1 class="text-white mb-6">Conversemos</h1>
        <p class="text-xl text-lum-slate-light max-w-2xl mx-auto">
          ¿Cuánto te cuesta no ver cómo va tu negocio hoy?
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Information -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Contact Details -->
          <div>
            <h2 class="mb-8 scroll-fade">Información de Contacto</h2>

            <div class="space-y-6">
              <!-- WhatsApp -->
              <div class="card-interactive scroll-fade">
                <a
                  href="https://wa.me/56991629095?text=Hola,%20me%20interesa%20conocer%20más%20sobre%20los%20servicios%20de%20Lumina%20Consulting"
                  target="_blank"
                  class="flex items-start gap-4"
                >
                  <div class="w-12 h-12 rounded-xl bg-[#25D366]/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-lg mb-1">WhatsApp</h3>
                    <p class="text-lum-coral font-medium">+56 9 9162 9095</p>
                    <p class="text-sm text-lum-slate mt-1">Respuesta rápida garantizada</p>
                  </div>
                </a>
              </div>

              <!-- Email -->
              <div class="card-interactive scroll-fade animation-delay-100">
                <a
                  href="mailto:jcepeda@luminaconsulting.ai"
                  class="flex items-start gap-4"
                >
                  <div class="w-12 h-12 rounded-xl bg-lum-coral/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-lg mb-1">Email</h3>
                    <p class="text-lum-coral font-medium">jcepeda@luminaconsulting.ai</p>
                    <p class="text-sm text-lum-slate mt-1">Respuesta en menos de 24 horas</p>
                  </div>
                </a>
              </div>

              <!-- Business Hours -->
              <div class="card scroll-fade animation-delay-200">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 rounded-xl bg-lum-coral/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-lg mb-1">Horario de Atención</h3>
                    <p class="text-lum-slate">Lunes a Viernes: 9:00 - 18:00 (GMT-3)</p>
                    <p class="text-sm text-lum-slate mt-1">Consultas urgentes por WhatsApp</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Response Guarantee -->
            <div class="mt-8 p-6 rounded-2xl bg-gradient-to-br from-lum-ivory to-white border border-lum-black/5 scroll-fade animation-delay-300">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-lum-success/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-lum-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg mb-2">Compromiso de Respuesta</h3>
                  <p class="text-lum-slate text-sm">
                    Nos comprometemos a responder todas las consultas en menos de 24 horas. Creemos en la comunicación directa y sin burocracia.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div>
            <h2 class="mb-8 scroll-fade">Envíanos un mensaje</h2>

            <form id="contact-page-form" class="space-y-5 scroll-fade">
              <div>
                <label for="page-name" class="block text-sm font-medium text-lum-charcoal mb-1.5">
                  Nombre <span class="text-lum-coral">*</span>
                </label>
                <input
                  type="text"
                  id="page-name"
                  name="user_name"
                  class="w-full px-4 py-3 border-2 border-lum-black bg-white transition-all duration-200 focus:outline-none focus:border-lum-coral focus:ring-2 focus:ring-lum-coral/20"
                  placeholder="Tu nombre"
                  required
                />
              </div>

              <div>
                <label for="page-email" class="block text-sm font-medium text-lum-charcoal mb-1.5">
                  Email <span class="text-lum-coral">*</span>
                </label>
                <input
                  type="email"
                  id="page-email"
                  name="user_email"
                  class="w-full px-4 py-3 border-2 border-lum-black bg-white transition-all duration-200 focus:outline-none focus:border-lum-coral focus:ring-2 focus:ring-lum-coral/20"
                  placeholder="tu@email.com"
                  required
                />
              </div>

              <div>
                <label for="page-company" class="block text-sm font-medium text-lum-charcoal mb-1.5">
                  Empresa
                </label>
                <input
                  type="text"
                  id="page-company"
                  name="company"
                  class="w-full px-4 py-3 border-2 border-lum-black bg-white transition-all duration-200 focus:outline-none focus:border-lum-coral focus:ring-2 focus:ring-lum-coral/20"
                  placeholder="Nombre de tu empresa (opcional)"
                />
              </div>

              <div>
                <label for="page-message" class="block text-sm font-medium text-lum-charcoal mb-1.5">
                  ¿En qué puedo ayudarte? <span class="text-lum-coral">*</span>
                </label>
                <textarea
                  id="page-message"
                  name="message"
                  rows="4"
                  class="w-full px-4 py-3 border-2 border-lum-black bg-white resize-none transition-all duration-200 focus:outline-none focus:border-lum-coral focus:ring-2 focus:ring-lum-coral/20"
                  placeholder="Cuéntame brevemente qué problema quieres resolver..."
                  required
                ></textarea>
              </div>

              <button
                type="submit"
                id="page-submit"
                class="btn-primary w-full justify-center py-3"
              >
                <span id="page-submit-text">Enviar mensaje</span>
                <span id="page-submit-loading" class="hidden items-center gap-2">
                  <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                  Enviando...
                </span>
              </button>

              <!-- Success message -->
              <div id="page-success" class="hidden p-6 text-center bg-lum-success/10 border-2 border-lum-success/30">
                <svg class="w-8 h-8 text-lum-success mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <p class="font-semibold text-lum-black">¡Mensaje enviado!</p>
                <p class="text-lum-slate text-sm mt-1">Te responderemos en menos de 24 horas.</p>
              </div>

              <!-- Error message -->
              <div id="page-error" class="hidden p-6 text-center bg-red-50 border-2 border-red-200">
                <p class="font-semibold text-lum-black">Error al enviar</p>
                <p class="text-lum-slate text-sm mt-1">Intenta de nuevo o contáctanos por WhatsApp.</p>
              </div>
            </form>

            <!-- Alternative contact methods -->
            <div class="mt-8 p-6 bg-lum-cream rounded-2xl text-center scroll-fade animation-delay-100">
              <p class="text-lum-slate text-sm mb-4">¿Prefieres otro canal?</p>
              <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a
                  href="https://wa.me/56991629095?text=Hola,%20me%20interesa%20conocer%20más%20sobre%20los%20servicios%20de%20Lumina%20Consulting"
                  target="_blank"
                  class="btn-primary text-sm py-2.5"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  WhatsApp
                </a>
                <a href="mailto:jcepeda@luminaconsulting.ai" class="btn-secondary text-sm py-2.5">
                  Email directo
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Presence Section -->
  <section class="py-24 section-light">
    <div class="container-custom">
      <div class="text-center mb-12 scroll-fade">
        <span class="badge mb-4">Alcance</span>
        <h2>Presencia en Chile y Servicios Remotos</h2>
        <p class="text-lum-slate mt-4 max-w-2xl mx-auto">
          Trabajamos con clientes en Chile y ofrecemos servicios remotos para empresas en toda Latinoamérica
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="card text-center scroll-fade">
          <div class="icon-container mx-auto mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg mb-2">Presencial en Chile</h3>
          <p class="text-sm text-lum-slate">Reuniones y capacitaciones presenciales disponibles</p>
        </div>

        <div class="card text-center scroll-fade animation-delay-100">
          <div class="icon-container mx-auto mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg mb-2">Trabajo Remoto</h3>
          <p class="text-sm text-lum-slate">Implementación y seguimiento 100% online</p>
        </div>

        <div class="card text-center scroll-fade animation-delay-200">
          <div class="icon-container mx-auto mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg mb-2">Alcance Internacional</h3>
          <p class="text-sm text-lum-slate">Clientes en múltiples países de Latinoamérica</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact form script -->
  <script>
    const ENDPOINT = 'https://wueqnruymfwbnkzwrdil.supabase.co/functions/v1/send-contact-message';

    const form = document.getElementById('contact-page-form') as HTMLFormElement;
    const submitBtn = document.getElementById('page-submit');
    const submitText = document.getElementById('page-submit-text');
    const submitLoading = document.getElementById('page-submit-loading');
    const successEl = document.getElementById('page-success');
    const errorEl = document.getElementById('page-error');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);

      submitBtn?.setAttribute('disabled', 'true');
      submitText?.classList.add('hidden');
      submitLoading?.classList.remove('hidden');
      submitLoading?.classList.add('flex');
      successEl?.classList.add('hidden');
      errorEl?.classList.add('hidden');

      try {
        const response = await fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            user_email: formData.get('user_email'),
            user_name: formData.get('user_name') || null,
            subject: `Contacto web: ${formData.get('company') || 'Sin empresa'}`,
            message: formData.get('message'),
            message_type: 'contact',
            page_context: 'luminaconsulting.ai/contacto'
          })
        });

        const data = await response.json();
        if (data.success) {
          form.classList.add('hidden');
          successEl?.classList.remove('hidden');
        } else {
          errorEl?.classList.remove('hidden');
        }
      } catch {
        errorEl?.classList.remove('hidden');
      } finally {
        submitBtn?.removeAttribute('disabled');
        submitText?.classList.remove('hidden');
        submitLoading?.classList.add('hidden');
        submitLoading?.classList.remove('flex');
      }
    });
  </script>
</Layout>
