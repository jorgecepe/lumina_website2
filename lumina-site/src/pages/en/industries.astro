---
import Layout from '../../layouts/Layout.astro';

const industries = [
  {
    name: 'Automotive',
    badge: 'badge-coral',
    description: 'Dealership networks: listing quality control, competitive price monitoring, commercial automation.',
    uses: [
      'Daily scraping and monitoring of own listings and competitors',
      'Alerts for listing errors (missing photos, out-of-range prices)',
      'Inventory, turnover, and margin dashboards by branch',
    ],
    caseLink: '/en/case-studies',
  },
  {
    name: 'Hospitality',
    badge: 'badge-mocha',
    description: 'Multi-property operations: reservation, accounting, and IoT integration for full operational and financial control.',
    uses: [
      'Cloudbeds + accounting (Softland, Xero) + financial indicators integration',
      'IoT automation (Home Assistant) synchronized with reservations',
      'Revenue dashboards by unit, booking lead time, guest origin',
    ],
    caseLink: '/en/case-studies',
  },
  {
    name: 'Aquaculture',
    badge: 'badge-sage',
    description: 'Document RPA on regulatory portals without API, traceability of permits and environmental obligations.',
    uses: [
      'Automation of filings on SEA, SERNAPESCA, DGA portals',
      '24/7 monitoring of due dates and regulatory changes',
      'Centralized document database by project',
    ],
    caseLink: '/en/case-studies',
  },
  {
    name: 'Industrial manufacturing',
    badge: 'badge-coral',
    description: 'BI on traditional ERPs (Softland, SAP B1, Dynamics): data models for operations, production, and finance.',
    uses: [
      'Power BI tabular models with multiple dimensions and facts',
      'DAX measures calibrated with management: margin, turnover, productivity',
      'Dashboards management uses daily, not just monthly',
    ],
    caseLink: '/en/case-studies',
  },
  {
    name: 'Veterinary and healthcare',
    badge: 'badge-mocha',
    description: 'Clinic networks in expansion: financial and operational visibility per location without relying on manual Excel.',
    uses: [
      'Integration with clinical management software',
      'Per-location dashboards: revenue, procedures, trends',
      'Automatic reports with no monthly exports',
    ],
    caseLink: '/en/case-studies',
  },
  {
    name: 'Real estate',
    badge: 'badge-sage',
    description: 'Holdings with rental assets: visibility of real profitability per unit, cash flow and projections.',
    uses: [
      'Consolidation of reservations, accounting, and indicators (UF, USD)',
      'Real-time per-unit profitability',
      'Projected vs. actual cash flow without depending on the accountant',
    ],
    caseLink: '/en/case-studies',
  },
  {
    name: 'Financial services',
    badge: 'badge-coral',
    description: 'Holdings and banks: HR Analytics, dynamic org charts, performance review calibration.',
    uses: [
      'NodalTree: interactive org charts from HR data',
      'Calibration systems with bias detection',
      'Organizational structure and headcount cost analysis',
    ],
    caseLink: '/en/case-studies',
  },
  {
    name: 'Public and regulated sector',
    badge: 'badge-mocha',
    description: 'Entities with complex reporting obligations: compliance and regulatory reporting automation.',
    uses: [
      'Automation of SII, UAF, CMF reports',
      'Document validation with AI agents',
      'Automated audits on operational data',
    ],
    caseLink: '/en/case-studies',
  },
];
---

<Layout
  title="Industries | Lumina Consulting's vertical expertise"
  description="Vertical expertise in automotive, hospitality, aquaculture, manufacturing, healthcare, real estate, financial services, and public sector. Industry-specific solutions."
>
  <!-- Hero -->
  <section class="relative py-16 md:py-24 bg-lum-black overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/4 -right-32 w-96 h-96 bg-lum-coral/15 rounded-full blur-3xl" />
      <div class="absolute bottom-0 -left-32 w-96 h-96 bg-lum-coral/10 rounded-full blur-3xl" />
    </div>
    <div class="container-custom relative">
      <div class="max-w-4xl mx-auto text-center">
        <span class="badge bg-white/10 text-white border-white/20 mb-6">Industry expertise</span>
        <h1 class="text-white mb-6">Industries</h1>
        <p class="text-xl text-lum-slate-light max-w-2xl mx-auto">
          I don't sell generic solutions. I know the ERPs, the processes, and the real problems of each sector I work in.
        </p>
      </div>
    </div>
  </section>

  <!-- Industries grid -->
  <section class="py-20 bg-white">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">
          {industries.map((ind) => (
            <div class="card scroll-fade">
              <span class={`${ind.badge} mb-4`}>{ind.name}</span>
              <p class="text-lum-slate mb-6">{ind.description}</p>

              <p class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-3">Typical use cases</p>
              <ul class="arrow-list mb-6">
                {ind.uses.map((uso) => <li>{uso}</li>)}
              </ul>

              <a href={ind.caseLink} class="inline-flex items-center gap-2 text-lum-coral hover:text-lum-mocha transition-colors font-medium text-sm">
                View case studies
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-lum-black relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-lum-coral/10 rounded-full blur-3xl" />
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-lum-coral/10 rounded-full blur-3xl" />
    </div>
    <div class="container-custom relative">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-white mb-6 scroll-fade">Your sector isn't on the list?</h2>
        <p class="text-xl text-lum-slate-light mb-10 scroll-fade animation-delay-100">
          Most of the problems I solve are transversal. Let's talk about yours.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center scroll-fade animation-delay-200">
          <a
            href="https://wa.me/56991629095?text=Hi,%20I'd%20like%20to%20discuss%20my%20industry"
            target="_blank"
            class="btn-primary"
          >
            Contact via WhatsApp
          </a>
          <a href="/en/contact" class="btn bg-transparent text-lum-cream border-lum-cream/30 hover:bg-lum-cream/10">
            Request Assessment
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
