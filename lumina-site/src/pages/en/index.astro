---
import Layout from '../../layouts/Layout.astro';
import WhatsAppIcon from '../../components/icons/WhatsAppIcon.astro';
---

<Layout
  title="Lumina Consulting | Data, automation & business intelligence for companies"
  description="Chilean consulting firm specializing in Power BI dashboards, AI-powered automation, management control, and custom solutions for mid-size companies."
>
  <!-- SECTION 1: HERO -->
  <section class="relative min-h-[75vh] lg:min-h-[90vh] flex items-center bg-lum-cream overflow-hidden">
    <div class="hidden lg:block absolute top-20 right-10 w-32 h-32 border-2 border-lum-mocha/20 rotate-12" aria-hidden="true"></div>
    <div class="hidden lg:block absolute bottom-32 left-20 w-16 h-16 bg-lum-coral/10" aria-hidden="true"></div>
    <div class="hidden lg:block absolute top-1/3 right-1/4 w-4 h-4 bg-lum-coral" aria-hidden="true"></div>

    <div class="container-custom relative py-20">
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-8">
          <div class="flex items-center gap-3 mb-8 scroll-fade">
            <span class="w-12 h-px bg-lum-coral"></span>
            <span class="font-mono text-mono-sm text-lum-coral uppercase tracking-wider">Data · Automation · Business Intelligence</span>
          </div>

          <h1 class="mb-8 scroll-fade delay-100">
            <span class="block text-lum-black">We connect your data</span>
            <span class="block">
              <span class="text-lum-black">so you </span>
              <span class="text-lum-coral italic">stop guessing</span>
            </span>
          </h1>

          <p class="text-lg sm:text-xl md:text-2xl text-lum-slate max-w-2xl mb-10 scroll-fade delay-200">
            I connect the systems your company already uses (ERP, sales platforms, databases), automate them, and give you the
            <span class="text-highlight">visibility you need</span>
            to make decisions with real information.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 scroll-fade delay-300">
            <a
              href="https://wa.me/56991629095?text=Hello,%20I'm%20interested%20in%20learning%20more%20about%20Lumina%20Consulting%20services"
              target="_blank"
              class="btn-primary w-full sm:w-auto"
            >
              <WhatsAppIcon />
              Let's talk
            </a>
            <a href="/en/services" class="btn-secondary w-full sm:w-auto">
              See services
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <div class="hidden lg:block lg:col-span-4 lg:translate-y-12 scroll-fade-right delay-400">
          <div class="relative -rotate-1">
            <div class="absolute inset-0 bg-lum-coral/20 translate-x-2 translate-y-2"></div>
            <img
              src="/images/chart3.png"
              alt="Management dashboard with KPIs, bar charts, distribution and process table. Lumina Consulting"
              class="relative w-full border-2 border-lum-black opacity-95"
              width="800"
              height="451"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: SOCIAL PROOF STRIP -->
  <section class="py-10 bg-lum-ivory border-y border-lum-border">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8 md:gap-y-0 md:gap-x-8 items-center">
        <div class="text-center scroll-fade md:border-r md:border-lum-border">
          <span class="font-display text-4xl md:text-5xl text-lum-coral block">5+</span>
          <span class="font-mono text-mono-xs text-lum-slate uppercase tracking-wider">Industries served</span>
        </div>
        <div class="text-center scroll-fade delay-100 md:border-r md:border-lum-border">
          <span class="font-display text-4xl md:text-5xl text-lum-coral block">4,000+</span>
          <span class="font-mono text-mono-xs text-lum-slate uppercase tracking-wider">Employees managed</span>
        </div>
        <div class="text-center scroll-fade delay-200 md:border-r md:border-lum-border">
          <span class="font-display text-4xl md:text-5xl text-lum-coral block">300+</span>
          <span class="font-mono text-mono-xs text-lum-slate uppercase tracking-wider">Vehicles monitored</span>
        </div>
        <div class="text-center scroll-fade delay-300">
          <span class="font-display text-4xl md:text-5xl text-lum-coral block">0</span>
          <span class="font-mono text-mono-xs text-lum-slate uppercase tracking-wider">Manual reports</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: FOUR PILLARS -->
  <section class="section bg-lum-cream">
    <div class="container-custom">
      <div class="max-w-2xl mb-16 scroll-fade">
        <span class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-4 block">What we do</span>
        <h2>Four lines to move your operations with data</h2>
      </div>

      <div class="space-y-12 md:space-y-16">
        <!-- Pillar 1: Business Intelligence -->
        <div class="border-l-4 border-lum-coral pl-8 md:pl-12 py-6 scroll-fade">
          <span class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider block mb-3">Business intelligence</span>
          <h3 class="mb-4">Business Intelligence and management control</h3>
          <p class="text-lum-slate max-w-3xl mb-4">
            First we help you decide what your leadership should measure to execute strategy. Then we build it into dashboards connected to your ERP that update themselves. Leadership sees sales, margins, cash flow, and operations, consolidated, every day.
          </p>
          <p class="text-lum-slate max-w-3xl mb-6">
            Income statements, budget vs. actual, KPIs with alerts. Power BI, Looker Studio, Softland, SAP Business One.
          </p>
          <p class="font-mono text-mono-sm text-lum-coral">
            > Real estate group with 7 entities: from monthly spreadsheets to daily cash flow visibility
          </p>
          <div class="flex flex-wrap gap-4 mt-6">
            <a href="/en/services/business-intelligence" class="btn-ghost">
              Learn more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Pillar 2: Automation and AI agents -->
        <div class="border-l-4 border-lum-mocha pl-8 md:pl-12 py-6 scroll-fade">
          <span class="font-mono text-mono-xs text-lum-mocha uppercase tracking-wider block mb-3">Automate the repetitive</span>
          <h3 class="mb-4">Automation and AI agents</h3>
          <p class="text-lum-slate max-w-3xl mb-4">
            Three families: automated flows between systems (n8n, Python, GitHub Actions), AI agents with your own data (RAG over manuals and contracts), and conversational assistants via web or WhatsApp connected to your PMS, CRM, or ERP.
          </p>
          <p class="text-lum-slate max-w-3xl mb-6">
            The systems detect failures before your team, and we resolve them within the agreed SLA.
          </p>
          <p class="font-mono text-mono-sm text-lum-mocha">
            > Automotive dealer network: from 3 hours of daily manual work to zero
          </p>
          <div class="flex flex-wrap gap-4 mt-6">
            <a href="/en/services/automation-and-ai-agents" class="btn-ghost">
              Learn more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Pillar 3: RPA platforms without API -->
        <div class="border-l-4 border-lum-sage pl-8 md:pl-12 py-6 scroll-fade">
          <span class="font-mono text-mono-xs text-lum-sage uppercase tracking-wider block mb-3">Platforms without APIs</span>
          <h3 class="mb-4">RPA for platforms without APIs</h3>
          <p class="text-lum-slate max-w-3xl mb-4">
            If your operation depends on uploading, downloading, or reconciling data in platforms that have no API (compliance portals, legacy systems, regulatory platforms), we automate that load without asking the provider for anything.
          </p>
          <p class="text-lum-slate max-w-3xl mb-6">
            Playwright plus AI-assisted analysis. Login, 2FA, navigation, file uploads, rejection detection. 24/7 monitoring and adjustments included when the platform changes.
          </p>
          <p class="font-mono text-mono-sm text-lum-sage">
            > LED lighting SME for aquaculture: document compliance across 9 platforms, measurable in real time
          </p>
          <div class="flex flex-wrap gap-4 mt-6">
            <a href="/en/services/rpa-platforms-without-api" class="btn-ghost">
              Learn more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Pillar 4: Custom solutions -->
        <div class="border-l-4 border-lum-slate pl-8 md:pl-12 py-6 scroll-fade">
          <span class="font-mono text-mono-xs text-lum-slate uppercase tracking-wider block mb-3">If it doesn't exist, we build it</span>
          <h3 class="mb-4">Custom solutions and infrastructure</h3>
          <p class="text-lum-slate max-w-3xl mb-4">
            When the problem isn't solved by a dashboard, an agent, or a standard automation, we build it to measure. Web applications with authentication, managed SFTP servers, custom data pipelines, payment integrations in complex corporate structures.
          </p>
          <p class="text-lum-slate max-w-3xl mb-6">
            The service includes infrastructure, deployment, monitoring, and monthly maintenance. Also corporate training applied to your real data.
          </p>
          <p class="font-mono text-mono-sm text-lum-slate">
            > NodalTree replaced USD $15,000/year software at a bank with 4,000+ employees
          </p>
          <div class="flex flex-wrap gap-4 mt-6">
            <a href="/en/services/custom-solutions" class="btn-ghost">
              Custom solutions
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/en/services/data-training" class="btn-ghost">
              Training
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: FOUNDER -->
  <section class="py-16 bg-lum-cream border-t border-lum-slate/10">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
          <div class="flex-shrink-0 scroll-fade">
            <a href="/en/about" class="block">
              <img
                src="/jorge-cepeda.jpg"
                alt="Jorge Cepeda - Founder of Lumina Consulting"
                class="w-32 h-32 md:w-44 md:h-44 rounded-full object-cover border-4 border-white shadow-lg hover:scale-105 transition-transform"
                loading="lazy"
                width="176"
                height="176"
              />
            </a>
          </div>

          <div class="flex-grow text-center md:text-left scroll-fade delay-100">
            <p class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-2">Founder</p>
            <h3 class="text-xl md:text-2xl font-display text-lum-black mb-3">
              Jorge Cepeda
            </h3>
            <p class="text-lum-slate text-sm mb-4">
              15 years designing management control systems in the financial industry. Today I apply that experience to mid-size companies that need the same visibility and control, without enterprise-level costs.
            </p>
            <div class="flex flex-wrap justify-center md:justify-start gap-3">
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white rounded-full text-sm text-lum-slate shadow-sm">
                <svg class="w-4 h-4 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                </svg>
                MBA UC
              </span>
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white rounded-full text-sm text-lum-slate shadow-sm">
                <svg class="w-4 h-4 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
                Professor U. Andes
              </span>
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white rounded-full text-sm text-lum-slate shadow-sm">
                <svg class="w-4 h-4 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                </svg>
                Microsoft PL-300
              </span>
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white rounded-full text-sm text-lum-slate shadow-sm">
                <svg class="w-4 h-4 text-lum-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                15+ years experience
              </span>
            </div>
          </div>

          <div class="flex-shrink-0 flex flex-col gap-3 scroll-fade delay-200">
            <a
              href="https://www.linkedin.com/in/jorgecepeda/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-lum-linkedin text-white rounded-lg hover:bg-lum-linkedin-dark transition-colors text-sm font-medium"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              View LinkedIn
            </a>
            <a href="/en/about" class="btn-ghost text-sm justify-center">
              More about Lumina
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 5: CASES -->
  <section class="section bg-lum-cream">
    <div class="container-custom">
      <div class="max-w-2xl mb-16 scroll-fade">
        <span class="font-mono text-mono-xs text-lum-coral uppercase tracking-wider mb-4 block">Real results</span>
        <h2>Case Studies</h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <!-- Case 1 -->
        <div class="border-l-4 border-lum-coral pl-8 py-4 scroll-fade">
          <div class="flex gap-3 mb-4">
            <span class="badge-coral">Automation</span>
            <span class="badge-outline">Automotive</span>
          </div>
          <h3 class="text-xl mb-3">Automotive Dealer Network: 300+ vehicles monitored daily</h3>
          <p class="text-lum-slate mb-4">
            From manually checking prices to receiving an automated ranking at 7 AM. From 3 hours of daily manual work to zero. Immediate detection of listing errors and off-market pricing.
          </p>
          <blockquote class="font-serif text-lg text-lum-charcoal italic mb-2">
            "It's like having an analyst working for us 24/7."
          </blockquote>
          <p class="font-mono text-mono-xs text-lum-slate">- Commercial Manager, automotive dealer network in Chile</p>
        </div>

        <!-- Case 2 -->
        <div class="border-l-4 border-lum-mocha pl-8 py-4 lg:translate-y-12 scroll-fade delay-100">
          <div class="flex gap-3 mb-4">
            <span class="badge-mocha">Dashboards</span>
            <span class="badge-outline">Real Estate</span>
          </div>
          <h3 class="text-xl mb-3">Real Estate Group: 7 entities with unified financial visibility</h3>
          <p class="text-lum-slate mb-4">
            Data scattered across Softland, Cloudbeds, and spreadsheets. Today the partners see real and projected cash flow in an automatic weekly email, with no manual intervention.
          </p>
          <blockquote class="font-serif text-lg text-lum-charcoal italic mb-2">
            "We went from requesting reports to having the information waiting for us."
          </blockquote>
          <p class="font-mono text-mono-xs text-lum-slate">- Managing Partner, real estate group</p>
        </div>
      </div>

      <div class="mt-12 text-center scroll-fade">
        <a href="/en/case-studies" class="btn-secondary">
          See more cases
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 6: NODALTREE -->
  <section class="section-mocha relative overflow-hidden">
    <div class="absolute top-10 right-10 w-40 h-40 border border-white/10 rotate-45" aria-hidden="true"></div>
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="scroll-fade">
          <span class="badge text-white border-white/30 mb-6">Our Product</span>
          <h2 class="text-white mb-4">NodalTree</h2>
          <p class="text-white/60 font-mono text-mono-sm uppercase tracking-wider mb-6">Smart org charts from your data</p>
          <p class="text-white/80 text-lg mb-6">
            Your org chart always up to date, without PowerPoint, without expensive software.
            Import from Excel, CSV, or database. Live editing, PDF export.
            Multi-tenancy: each company with its own space.
          </p>
          <p class="font-mono text-mono-sm text-white/70 mb-8">
            > Used by a bank with 4,000+ employees. Replaced USD $15,000/year software.
          </p>
          <a
            href="https://nodaltree.luminaconsulting.ai"
            target="_blank"
            rel="noopener noreferrer"
            class="btn bg-white text-lum-mocha-dark border-white hover:bg-lum-cream"
          >
            Try NodalTree
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
        <div class="scroll-fade-right">
          <div class="bg-white/10 border border-white/20 p-8 rotate-1">
            <img
              src="/logoNodalTree.png"
              alt="NodalTree: Interactive org charts from your data"
              class="w-32 h-32 object-contain mx-auto opacity-90"
              loading="lazy"
              width="128"
              height="128"
            />
            <p class="text-white/40 text-center font-mono text-mono-xs mt-4">Preview coming soon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 7: FINAL CTA -->
  <section class="section-dark relative overflow-hidden">
    <div class="absolute top-1/2 right-20 -translate-y-1/2 opacity-10" aria-hidden="true">
      <div class="w-32 h-px bg-lum-coral"></div>
      <div class="w-px h-32 bg-lum-coral absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
    </div>

    <div class="container-custom">
      <div class="max-w-3xl">
        <h2 class="text-lum-cream mb-6 scroll-fade">
          How much does it cost you not to see
          <span class="text-lum-coral italic">how your business is doing today</span>?
        </h2>
        <p class="text-xl text-lum-slate-light mb-10 scroll-fade delay-100">
          We respond within 24 hours. No commitment.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 scroll-fade delay-200">
          <a
            href="https://wa.me/56991629095?text=Hello,%20I'm%20interested%20in%20learning%20more%20about%20Lumina%20Consulting%20services"
            target="_blank"
            class="btn-primary"
