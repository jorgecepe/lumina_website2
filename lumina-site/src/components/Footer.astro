---
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
const currentYear = new Date().getFullYear();

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isContactPage = currentPath === '/contacto' || currentPath === '/en/contact';
const isEnglish = currentPath.startsWith('/en');

const quickLinks = isEnglish ? [
  { href: '/en', label: 'Home' },
  { href: '/en/about', label: 'About' },
  { href: '/en/services', label: 'Services' },
  { href: '/en/industries', label: 'Industries' },
  { href: '/en/case-studies', label: 'Cases' },
  { href: '/en/contact', label: 'Contact' },
] : [
  { href: '/', label: 'Inicio' },
  { href: '/acerca-de', label: 'Nosotros' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/industrias', label: 'Industrias' },
  { href: '/casos-de-exito', label: 'Casos' },
  { href: '/contacto', label: 'Contacto' },
];

const services = isEnglish ? [
  { label: 'Business Intelligence', href: '/en/services/business-intelligence' },
  { label: 'Automation & AI Agents', href: '/en/services/automation-and-ai-agents' },
  { label: 'RPA (platforms without API)', href: '/en/services/rpa-platforms-without-api' },
  { label: 'Custom solutions', href: '/en/services/custom-solutions' },
  { label: 'Competitive intelligence', href: '/en/services/competitive-analysis' },
  { label: 'HR Analytics', href: '/en/services/hr-analytics' },
  { label: 'Training', href: '/en/services/data-training' },
] : [
  { label: 'Business Intelligence', href: '/servicios/business-intelligence' },
  { label: 'Automatización y agentes IA', href: '/servicios/automatizacion-y-agentes-ia' },
  { label: 'RPA (plataformas sin API)', href: '/servicios/rpa-plataformas-sin-api' },
  { label: 'Soluciones a medida', href: '/servicios/soluciones-a-medida' },
  { label: 'Inteligencia competitiva', href: '/servicios/inteligencia-competitiva' },
  { label: 'HR Analytics', href: '/servicios/hr-analytics' },
  { label: 'Capacitación', href: '/servicios/capacitacion' },
];

const secondaryLinks = isEnglish ? [
  { label: 'Blog', href: '/en/blog' },
  { label: 'Resources', href: '/en/resources' },
  { label: 'FAQ', href: '/en/faq' },
  { label: 'NodalTree', href: 'https://nodaltree.luminaconsulting.ai', external: true },
] : [
  { label: 'Blog', href: '/blog' },
  { label: 'Recursos', href: '/recursos' },
  { label: 'FAQ', href: '/faq' },
  { label: 'NodalTree', href: 'https://nodaltree.luminaconsulting.ai', external: true },
];

const t = {
  nav: isEnglish ? 'Navigation' : 'Navegación',
  more: isEnglish ? 'More' : 'Más',
  services: isEnglish ? 'Services' : 'Servicios',
  contact: isEnglish ? 'Contact' : 'Contacto',
  tagline: isEnglish
    ? 'We connect your company\'s data so leadership can make decisions with real information.'
    : 'Conectamos los datos de tu empresa para que la gerencia tome decisiones con información real.',
  location: isEnglish ? 'Chile · Remote services' : 'Chile · Servicios remotos',
  privacy: isEnglish ? 'Privacy' : 'Privacidad',
  terms: isEnglish ? 'Terms' : 'Términos',
  waLabel: isEnglish ? 'Contact via WhatsApp' : 'Contactar por WhatsApp',
  waMessage: isEnglish
    ? 'Hello,%20I\'m%20interested%20in%20learning%20more%20about%20Lumina%20Consulting%20services'
    : 'Hola,%20me%20interesa%20conocer%20más%20sobre%20los%20servicios%20de%20Lumina%20Consulting',
};
---

<footer class="bg-lum-black text-lum-cream relative overflow-hidden">
  <!-- Decorative element -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-lum-coral/30 to-transparent" aria-hidden="true"></div>

  <div class="container-custom py-16 relative">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-8 md:gap-12 lg:gap-8 mb-12">
      <!-- Company Info - larger column -->
      <div class="lg:col-span-4">
        <a href={isEnglish ? '/en' : '/'} class="inline-block mb-6 group">
          <!-- Logo text fallback for dark background -->
          <span class="font-serif text-2xl text-lum-cream group-hover:text-lum-coral transition-colors">
            <span class="text-lum-coral">L</span>umina
          </span>
        </a>
        <p class="text-lum-slate-light text-sm leading-relaxed mb-6 max-w-xs">
          {t.tagline}
        </p>

        <!-- Social links with brutalist style -->
        <div class="flex gap-2">
          <a
            href="https://wa.me/56991629095"
            target="_blank"
            class="w-11 h-11 border border-lum-stone hover:border-lum-coral hover:bg-lum-coral flex items-center justify-center transition-all duration-300 group"
            aria-label="WhatsApp"
          >
            <WhatsAppIcon class="w-5 h-5 text-lum-slate-light group-hover:text-white transition-colors" />
          </a>
          <a
            href="mailto:jcepeda@luminaconsulting.ai"
            class="w-11 h-11 border border-lum-stone hover:border-lum-mocha hover:bg-lum-mocha flex items-center justify-center transition-all duration-300 group"
            aria-label="Email"
          >
            <svg class="w-5 h-5 text-lum-slate-light group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
          <a
            href="https://github.com/jorgecepe"
            target="_blank"
            class="w-11 h-11 border border-lum-stone hover:border-lum-slate-light hover:bg-lum-charcoal flex items-center justify-center transition-all duration-300 group"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5 text-lum-slate-light group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="lg:col-span-2">
        <h4 class="font-mono text-mono-xs uppercase tracking-wider text-lum-coral mb-6">{t.nav}</h4>
        <ul class="space-y-3">
          {quickLinks.map((link, index) => (
            <li>
              <a
                href={link.href}
                class="text-lum-slate-light hover:text-lum-cream transition-colors duration-200 text-sm flex items-center gap-2 group"
              >
                <span class="font-mono text-xs text-lum-stone group-hover:text-lum-coral transition-colors">0{index + 1}</span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <h4 class="font-mono text-mono-xs uppercase tracking-wider text-lum-mocha mb-4 mt-8">{t.more}</h4>
        <ul class="space-y-3">
          {secondaryLinks.map(link => (
            <li>
              <a
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
                class="text-lum-slate-light hover:text-lum-cream transition-colors duration-200 text-sm flex items-center gap-2 group"
              >
                {link.label}
                {link.external && (
                  <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div class="lg:col-span-3">
        <h4 class="font-mono text-mono-xs uppercase tracking-wider text-lum-coral mb-6">{t.services}</h4>
        <ul class="space-y-3">
          {services.map(service => (
            <li>
              <a
                href={service.href}
                class="text-lum-slate-light hover:text-lum-cream transition-colors duration-200 text-sm flex items-start gap-2 group"
              >
                <span class="w-1.5 h-1.5 bg-lum-mocha mt-2 flex-shrink-0 group-hover:bg-lum-coral transition-colors"></span>
                {service.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="lg:col-span-3">
        <h4 class="font-mono text-mono-xs uppercase tracking-wider text-lum-coral mb-6">{t.contact}</h4>
        <ul class="space-y-4">
          <li>
            <a
              href="mailto:jcepeda@luminaconsulting.ai"
              class="text-lum-slate-light hover:text-lum-cream transition-colors duration-200 text-sm flex items-start gap-3 group"
            >
              <span class="w-1 h-4 bg-lum-coral mt-0.5"></span>
              <span>jcepeda@luminaconsulting.ai</span>
            </a>
          </li>
          <li>
            <a
              href="https://wa.me/56991629095"
              target="_blank"
              class="text-lum-slate-light hover:text-lum-cream transition-colors duration-200 text-sm flex items-start gap-3 group"
            >
              <span class="w-1 h-4 bg-lum-coral mt-0.5"></span>
              <span>+56 9 9162 9095</span>
            </a>
          </li>
          <li class="text-lum-slate-light text-sm flex items-start gap-3">
            <span class="w-1 h-4 bg-lum-mocha mt-0.5"></span>
            <span>{t.location}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-lum-stone pt-8">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-lum-slate-light text-sm font-mono">
          <span class="text-lum-coral">//</span> {currentYear} Lumina Consulting
        </p>
        <div class="flex items-center gap-6 text-sm">
          <a href={isEnglish ? '/en/privacy' : '/privacidad'} class="text-lum-slate-light hover:text-lum-cream transition-colors duration-200 font-mono text-xs">
            {t.privacy}
          </a>
          <span class="text-lum-stone">/</span>
          <a href={isEnglish ? '/en/terms' : '/terminos'} class="text-lum-slate-light hover:text-lum-cream transition-colors duration-200 font-mono text-xs">
            {t.terms}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

{!isContactPage && (
  <!-- WhatsApp Floating Button - Brutalist style -->
  <a
    href={`https://wa.me/56991629095?text=${t.waMessage}`}
    target="_blank"
    class="fixed bottom-6 right-6 bg-lum-coral hover:bg-lum-coral-dark text-white p-4 transition-all duration-300 hover:-translate-y-1 z-50 group border-2 border-lum-black"
    style="box-shadow: 4px 4px 0px 0px var(--color-lum-black, #1a1814);"
    aria-label={t.waLabel}
  >
    <WhatsAppIcon class="w-6 h-6 transition-transform duration-300 group-hover:scale-110" />
  </a>
)}
