{
  "redirects": [
    { "source": "/servicios/automatizacion-reporteria", "destination": "/servicios/automatizacion-inteligente", "permanent": true },
    { "source": "/servicios/analisis-competencia", "destination": "/servicios/inteligencia-competitiva", "permanent": true },
    { "source": "/servicios/capacitacion-sence", "destination": "/servicios/capacitacion", "permanent": true }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "astro",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "all"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ]
}
